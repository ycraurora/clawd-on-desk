{
  "name": "clawd-terminal-focus",
  "displayName": "Clawd Terminal Focus",
  "description": "Enables Clawd desktop pet to focus the correct terminal tab and bridge remote Codex activity",
  "version": "0.3.3",
  "publisher": "clawd",
  "engines": {
    "vscode": "^1.70.0"
  },
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri",
    "onCommand:clawd.internal.forwardStateToApp",
    "onCommand:clawd.internal.bridgeLog",
    "onCommand:clawd.showBridgeStatus"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "clawd.showBridgeStatus",
        "title": "Clawd: Show Local Bridge Status"
      },
      {
        "command": "clawd.internal.forwardStateToApp",
        "title": "Clawd Internal: Forward State To App"
      },
      {
        "command": "clawd.internal.bridgeLog",
        "title": "Clawd Internal: Bridge Log"
      }
    ]
  }
}
